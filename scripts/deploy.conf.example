# Конфигурация деплоя 4eburnet
# Скопируй в deploy.conf и заполни:
#   cp scripts/deploy.conf.example scripts/deploy.conf
#
# ВНИМАНИЕ: deploy.conf добавлен в .gitignore — не коммитить!

# === Режим разработки (QEMU VM) ===
ROUTER_IP=localhost
ROUTER_PORT=2222
ROUTER_USER=root
ROUTER_ARCH=x86_64
LUCI_PORT=8080
SDK_PATH=~/4eburnet-dev/sdk/aarch64/sdk-aarch64
BUILD_DIR=~/4eburnet-dev/project/4eburnet/build

# === Реальный роутер EC330 (раскомментировать после восстановления) ===
# ROUTER_IP=192.168.2.1
# ROUTER_PORT=22
# ROUTER_USER=root
# ROUTER_ARCH=mipsel_24kc
# SDK_PATH=~/4eburnet-dev/sdk/mipsel-mt7621/sdk-mipsel-mt7621
# BUILD_DIR=~/4eburnet-dev/project/4eburnet/build

# === Flint 2 (когда придёт время) ===
