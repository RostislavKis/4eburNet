CC = musl-gcc

# ── Профили сборки (PROFILE=micro|normal|full) ──
PROFILE ?= full

ifeq ($(PROFILE),micro)
  KCONFIG_CFLAGS := \
    -DCONFIG_EBURNET_VLESS=1    \
    -DCONFIG_EBURNET_TROJAN=1   \
    -DCONFIG_EBURNET_SS=0       \
    -DCONFIG_EBURNET_AWG=0      \
    -DCONFIG_EBURNET_FAKE_IP=0  \
    -DCONFIG_EBURNET_DOH=1      \
    -DCONFIG_EBURNET_QUIC=1     \
    -DCONFIG_EBURNET_PROXY_PROVIDERS=0 \
    -DCONFIG_EBURNET_SNIFFER=1  \
    -DCONFIG_EBURNET_DPI=1      \
    -DCONFIG_EBURNET_STLS=0     \
    -DCONFIG_EBURNET_DOQ=0
else ifeq ($(PROFILE),normal)
  KCONFIG_CFLAGS := \
    -DCONFIG_EBURNET_VLESS=1    \
    -DCONFIG_EBURNET_TROJAN=1   \
    -DCONFIG_EBURNET_SS=1       \
    -DCONFIG_EBURNET_AWG=0      \
    -DCONFIG_EBURNET_FAKE_IP=1  \
    -DCONFIG_EBURNET_DOH=1      \
    -DCONFIG_EBURNET_QUIC=1     \
    -DCONFIG_EBURNET_PROXY_PROVIDERS=1 \
    -DCONFIG_EBURNET_SNIFFER=1  \
    -DCONFIG_EBURNET_DPI=1      \
    -DCONFIG_EBURNET_STLS=1     \
    -DCONFIG_EBURNET_DOQ=0
else  # full — все функции включены
  KCONFIG_CFLAGS := \
    -DCONFIG_EBURNET_VLESS=1    \
    -DCONFIG_EBURNET_TROJAN=1   \
    -DCONFIG_EBURNET_SS=1       \
    -DCONFIG_EBURNET_AWG=1      \
    -DCONFIG_EBURNET_FAKE_IP=1  \
    -DCONFIG_EBURNET_DOH=1      \
    -DCONFIG_EBURNET_QUIC=1     \
    -DCONFIG_EBURNET_PROXY_PROVIDERS=1 \
    -DCONFIG_EBURNET_SNIFFER=1  \
    -DCONFIG_EBURNET_DPI=1      \
    -DCONFIG_EBURNET_STLS=1     \
    -DCONFIG_EBURNET_DOQ=0
endif

CFLAGS = -std=c2x -Wall -Wextra -Wpedantic -O2 -flto -pipe -D_GNU_SOURCE -static \
         -fstack-protector-strong -D_FORTIFY_SOURCE=2 \
         -ffunction-sections -fdata-sections \
         $(KCONFIG_CFLAGS)
CFLAGS += -Werror
WOLFSSL_PREFIX ?= /usr/local/musl-wolfssl
INCLUDES = -Iinclude -I$(WOLFSSL_PREFIX)/include
LDFLAGS = -L$(WOLFSSL_PREFIX)/lib -lwolfssl -lm -Wl,--gc-sections
SRCDIR = src
BUILDDIR = ../../build
SOURCES = $(SRCDIR)/main.c $(SRCDIR)/log.c $(SRCDIR)/resource_manager.c $(SRCDIR)/config.c $(SRCDIR)/ipc.c $(SRCDIR)/stats.c \
          $(SRCDIR)/routing/nftables.c $(SRCDIR)/routing/policy.c \
          $(SRCDIR)/proxy/tproxy.c $(SRCDIR)/proxy/dispatcher.c \
          $(SRCDIR)/routing/rules_loader.c $(SRCDIR)/ntp_bootstrap.c \
          $(SRCDIR)/crypto/tls.c \
          $(SRCDIR)/proxy/protocols/vless.c \
          $(SRCDIR)/proxy/protocols/vless_xhttp.c \
          $(SRCDIR)/proxy/protocols/trojan.c \
          $(SRCDIR)/proxy/protocols/shadowsocks.c \
          $(SRCDIR)/crypto/blake3.c \
          $(SRCDIR)/crypto/blake2s.c $(SRCDIR)/crypto/blake2b.c \
          $(SRCDIR)/crypto/quic_salamander.c \
          $(SRCDIR)/proxy/protocols/hysteria2.c \
          $(SRCDIR)/proxy/protocols/hysteria2_udp.c \
          $(SRCDIR)/proxy/protocols/hysteria2_cc.c \
          $(SRCDIR)/crypto/noise.c \
          $(SRCDIR)/proxy/protocols/awg.c \
          $(SRCDIR)/routing/device_policy.c \
          $(SRCDIR)/proxy/proxy_group.c \
          $(SRCDIR)/proxy/rule_provider.c \
          $(SRCDIR)/proxy/proxy_provider.c \
          $(SRCDIR)/proxy/rules_engine.c \
          $(SRCDIR)/proxy/sniffer.c \
          $(SRCDIR)/net_utils.c \
          $(SRCDIR)/dns/dns_packet.c $(SRCDIR)/dns/dns_cache.c \
          $(SRCDIR)/dns/dns_rules.c $(SRCDIR)/dns/dns_upstream.c \
          $(SRCDIR)/dns/dns_upstream_async.c \
          $(SRCDIR)/dns/dns_server.c \
          $(SRCDIR)/dns/dns_resolver.c \
          $(SRCDIR)/dns/fake_ip.c \
          $(SRCDIR)/dns/dns_upstream_doq.c \
          $(SRCDIR)/crypto/quic.c \
          $(SRCDIR)/geo/geo_loader.c \
          $(SRCDIR)/dpi/dpi_filter.c \
          $(SRCDIR)/dpi/dpi_payload.c \
          $(SRCDIR)/dpi/dpi_strategy.c \
          $(SRCDIR)/dpi/cdn_updater.c \
          $(SRCDIR)/crypto/hmac_sha256.c \
          $(SRCDIR)/proxy/protocols/shadowtls.c
TARGET = $(BUILDDIR)/4eburnetd

# StrictHostKeyChecking=no: только для dev QEMU VM (127.0.0.1:2222)
SSH = ssh -p 2222 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@127.0.0.1

all: $(TARGET)

$(TARGET): $(SOURCES) include/*.h
	mkdir -p $(BUILDDIR)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $(SOURCES) $(LDFLAGS)
	@ls -lh $@

clean:
	rm -f $(TARGET)

run: $(TARGET)
	$(TARGET) -c ../../qemu/test-config/4eburnet

install-vm: $(TARGET)
	cat $(TARGET) | $(SSH) "cat > /usr/sbin/4eburnetd && chmod +x /usr/sbin/4eburnetd"
	cat ../../qemu/test-config/4eburnet | $(SSH) "cat > /etc/config/4eburnet"
	@echo "Деплой завершён. Запусти: ssh -p 2222 root@localhost \"4eburnetd -d\""

WOLFSSL_INCLUDES = -I$(WOLFSSL_PREFIX)/include
WOLFSSL_LIBS     = -L$(WOLFSSL_PREFIX)/lib -lwolfssl -lm
TEST_CC  = musl-gcc
TEST_FLAGS = -std=c11 -O2 -D_GNU_SOURCE -DCONFIG_EBURNET_QUIC=1

HY2_COMMON = src/crypto/blake2b.c src/crypto/quic_salamander.c \
             src/crypto/quic.c src/proxy/protocols/hysteria2_cc.c \
             src/proxy/protocols/hysteria2.c

test-uri:
	$(TEST_CC) $(TEST_FLAGS) $(INCLUDES) $(WOLFSSL_INCLUDES) \
	  $(HY2_COMMON) \
	  tests/test_hysteria2_uri.c \
	  -o /tmp/test_hysteria2_uri $(WOLFSSL_LIBS)
	/tmp/test_hysteria2_uri

test-udp:
	$(TEST_CC) $(TEST_FLAGS) $(INCLUDES) $(WOLFSSL_INCLUDES) \
	  $(HY2_COMMON) \
	  src/proxy/protocols/hysteria2_udp.c \
	  tests/test_hysteria2_udp.c \
	  -o /tmp/test_hysteria2_udp $(WOLFSSL_LIBS)
	/tmp/test_hysteria2_udp

test-cc:
	$(TEST_CC) $(TEST_FLAGS) $(INCLUDES) \
	  src/proxy/protocols/hysteria2_cc.c \
	  tests/test_hysteria2_cc.c \
	  -o /tmp/test_hysteria2_cc
	/tmp/test_hysteria2_cc

test-dpi-filter:
	$(TEST_CC) $(TEST_FLAGS) -DCONFIG_EBURNET_DPI=1 \
	  $(INCLUDES) \
	  src/dpi/dpi_filter.c \
	  tests/test_dpi_filter.c \
	  -o /tmp/test_dpi_filter
	/tmp/test_dpi_filter

test-dpi-payload:
	$(TEST_CC) $(TEST_FLAGS) -DCONFIG_EBURNET_DPI=1 \
	  $(INCLUDES) \
	  src/dpi/dpi_payload.c \
	  tests/test_dpi_payload.c \
	  -o /tmp/test_dpi_payload
	/tmp/test_dpi_payload

test-dpi-strategy:
	$(TEST_CC) $(TEST_FLAGS) -DCONFIG_EBURNET_DPI=1 \
	  $(INCLUDES) \
	  src/dpi/dpi_filter.c \
	  src/dpi/dpi_payload.c \
	  src/dpi/dpi_strategy.c \
	  tests/test_dpi_strategy.c \
	  -o /tmp/test_dpi_strategy
	/tmp/test_dpi_strategy

test-cdn-updater:
	$(TEST_CC) $(TEST_FLAGS) -DCONFIG_EBURNET_DPI=1 \
	  $(INCLUDES) $(WOLFSSL_INCLUDES) \
	  src/net_utils.c \
	  src/crypto/tls.c \
	  src/dpi/dpi_filter.c \
	  src/dpi/dpi_payload.c \
	  src/dpi/cdn_updater.c \
	  tests/test_cdn_updater.c \
	  -o /tmp/test_cdn_updater $(WOLFSSL_LIBS)
	/tmp/test_cdn_updater

test-hmac-sha256:
	$(TEST_CC) $(TEST_FLAGS) -DCONFIG_EBURNET_STLS=1 \
	  $(INCLUDES) $(WOLFSSL_INCLUDES) \
	  src/crypto/hmac_sha256.c \
	  tests/test_hmac_sha256.c \
	  -o /tmp/test_hmac_sha256 $(WOLFSSL_LIBS)
	/tmp/test_hmac_sha256

test-shadowtls:
	$(TEST_CC) $(TEST_FLAGS) -DCONFIG_EBURNET_STLS=1 -DCONFIG_EBURNET_DPI=1 \
	  $(INCLUDES) $(WOLFSSL_INCLUDES) \
	  src/log.c \
	  src/crypto/hmac_sha256.c \
	  src/dpi/dpi_payload.c \
	  src/proxy/protocols/shadowtls.c \
	  tests/test_shadowtls.c \
	  -o /tmp/test_shadowtls $(WOLFSSL_LIBS)
	/tmp/test_shadowtls

test: test-uri test-udp test-cc test-dpi-filter test-dpi-payload test-dpi-strategy test-cdn-updater test-hmac-sha256 test-shadowtls

# ── Cross-compilation (Путь A: prebuilt binary → ipk) ─────────────
SDK_BASE         ?= $(HOME)/4eburnet-dev/sdk
TC_MIPSEL        ?= $(SDK_BASE)/mipsel/sdk-mipsel/staging_dir/toolchain-mipsel_gcc-12.3.0_musl/bin
TC_AARCH64       ?= $(SDK_BASE)/aarch64/sdk-aarch64/staging_dir/toolchain-aarch64_cortex-a53_gcc-13.3.0_musl/bin
WOLFSSL_MIPSEL   ?= /usr/local/musl-wolfssl-mipsel
WOLFSSL_AARCH64  ?= /usr/local/musl-wolfssl-aarch64
PREBUILT_DIR     ?= ../prebuilt

cross-mipsel:
	@echo "=== Cross-compile 4eburnetd для mipsel ==="
	$(MAKE) -f Makefile.dev PROFILE=full \
		CC=$(TC_MIPSEL)/mipsel-openwrt-linux-musl-gcc \
		WOLFSSL_PREFIX=$(WOLFSSL_MIPSEL) \
		TARGET=$(BUILDDIR)/4eburnetd-mipsel clean all
	$(TC_MIPSEL)/mipsel-openwrt-linux-musl-strip --strip-all $(BUILDDIR)/4eburnetd-mipsel
	mkdir -p $(PREBUILT_DIR)/mipsel
	cp $(BUILDDIR)/4eburnetd-mipsel $(PREBUILT_DIR)/mipsel/4eburnetd
	ls -lh $(PREBUILT_DIR)/mipsel/4eburnetd

cross-aarch64:
	@echo "=== Cross-compile 4eburnetd для aarch64 ==="
	$(MAKE) -f Makefile.dev PROFILE=full \
		CC=$(TC_AARCH64)/aarch64-openwrt-linux-musl-gcc \
		WOLFSSL_PREFIX=$(WOLFSSL_AARCH64) \
		TARGET=$(BUILDDIR)/4eburnetd-aarch64 clean all
	$(TC_AARCH64)/aarch64-openwrt-linux-musl-strip --strip-all $(BUILDDIR)/4eburnetd-aarch64
	mkdir -p $(PREBUILT_DIR)/aarch64
	cp $(BUILDDIR)/4eburnetd-aarch64 $(PREBUILT_DIR)/aarch64/4eburnetd
	ls -lh $(PREBUILT_DIR)/aarch64/4eburnetd

.PHONY: all clean run install-vm test test-uri test-udp test-cc test-dpi-filter test-dpi-payload test-dpi-strategy test-cdn-updater test-hmac-sha256 test-shadowtls cross-mipsel cross-aarch64
