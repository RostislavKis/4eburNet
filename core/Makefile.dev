CC = musl-gcc

# ── Профили сборки (PROFILE=micro|normal|full) ──
PROFILE ?= full

ifeq ($(PROFILE),micro)
  KCONFIG_CFLAGS := \
    -DCONFIG_EBURNET_VLESS=1    \
    -DCONFIG_EBURNET_TROJAN=1   \
    -DCONFIG_EBURNET_SS=0       \
    -DCONFIG_EBURNET_AWG=0      \
    -DCONFIG_EBURNET_FAKE_IP=0  \
    -DCONFIG_EBURNET_DOH=1      \
    -DCONFIG_EBURNET_QUIC=1     \
    -DCONFIG_EBURNET_PROXY_PROVIDERS=0 \
    -DCONFIG_EBURNET_SNIFFER=1
else ifeq ($(PROFILE),normal)
  KCONFIG_CFLAGS := \
    -DCONFIG_EBURNET_VLESS=1    \
    -DCONFIG_EBURNET_TROJAN=1   \
    -DCONFIG_EBURNET_SS=1       \
    -DCONFIG_EBURNET_AWG=0      \
    -DCONFIG_EBURNET_FAKE_IP=1  \
    -DCONFIG_EBURNET_DOH=1      \
    -DCONFIG_EBURNET_QUIC=1     \
    -DCONFIG_EBURNET_PROXY_PROVIDERS=1 \
    -DCONFIG_EBURNET_SNIFFER=1
else
  KCONFIG_CFLAGS := \
    -DCONFIG_EBURNET_QUIC=1
endif

CFLAGS = -std=c2x -Wall -Wextra -Wpedantic -O2 -flto -pipe -D_GNU_SOURCE -static \
         $(KCONFIG_CFLAGS)
WOLFSSL_PREFIX ?= /usr/local/musl-wolfssl
INCLUDES = -Iinclude -I$(WOLFSSL_PREFIX)/include
LDFLAGS = -L$(WOLFSSL_PREFIX)/lib -lwolfssl -lm
SRCDIR = src
BUILDDIR = ../../build
SOURCES = $(SRCDIR)/main.c $(SRCDIR)/log.c $(SRCDIR)/resource_manager.c $(SRCDIR)/config.c $(SRCDIR)/ipc.c \
          $(SRCDIR)/routing/nftables.c $(SRCDIR)/routing/policy.c \
          $(SRCDIR)/proxy/tproxy.c $(SRCDIR)/proxy/dispatcher.c \
          $(SRCDIR)/routing/rules_loader.c $(SRCDIR)/ntp_bootstrap.c \
          $(SRCDIR)/crypto/tls.c \
          $(SRCDIR)/proxy/protocols/vless.c \
          $(SRCDIR)/proxy/protocols/vless_xhttp.c \
          $(SRCDIR)/proxy/protocols/trojan.c \
          $(SRCDIR)/proxy/protocols/shadowsocks.c \
          $(SRCDIR)/crypto/blake3.c \
          $(SRCDIR)/crypto/blake2s.c $(SRCDIR)/crypto/blake2b.c \
          $(SRCDIR)/crypto/quic_salamander.c \
          $(SRCDIR)/proxy/protocols/hysteria2.c \
          $(SRCDIR)/crypto/noise.c \
          $(SRCDIR)/proxy/protocols/awg.c \
          $(SRCDIR)/routing/device_policy.c \
          $(SRCDIR)/proxy/proxy_group.c \
          $(SRCDIR)/proxy/rule_provider.c \
          $(SRCDIR)/proxy/proxy_provider.c \
          $(SRCDIR)/proxy/rules_engine.c \
          $(SRCDIR)/proxy/sniffer.c \
          $(SRCDIR)/net_utils.c \
          $(SRCDIR)/dns/dns_packet.c $(SRCDIR)/dns/dns_cache.c \
          $(SRCDIR)/dns/dns_rules.c $(SRCDIR)/dns/dns_upstream.c \
          $(SRCDIR)/dns/dns_upstream_async.c \
          $(SRCDIR)/dns/dns_server.c \
          $(SRCDIR)/dns/dns_resolver.c \
          $(SRCDIR)/dns/fake_ip.c \
          $(SRCDIR)/dns/dns_upstream_doq.c \
          $(SRCDIR)/crypto/quic.c \
          $(SRCDIR)/geo/geo_loader.c
TARGET = $(BUILDDIR)/4eburnetd

# StrictHostKeyChecking=no: только для dev QEMU VM (127.0.0.1:2222)
SSH = ssh -p 2222 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@127.0.0.1

all: $(TARGET)

$(TARGET): $(SOURCES) include/*.h
	mkdir -p $(BUILDDIR)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $(SOURCES) $(LDFLAGS)
	@ls -lh $@

clean:
	rm -f $(TARGET)

run: $(TARGET)
	$(TARGET) -c ../../qemu/test-config/4eburnet

install-vm: $(TARGET)
	cat $(TARGET) | $(SSH) "cat > /usr/sbin/4eburnetd && chmod +x /usr/sbin/4eburnetd"
	cat ../../qemu/test-config/4eburnet | $(SSH) "cat > /etc/config/4eburnet"
	@echo "Деплой завершён. Запусти: ssh -p 2222 root@localhost \"4eburnetd -d\""

.PHONY: all clean run install-vm
