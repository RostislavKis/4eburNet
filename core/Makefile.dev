# ── geo_compile (инструмент компиляции .lst → .gbin) ──────────────

geo-compile:
	$(CC) -std=gnu2x -O2 -Iinclude -o ../tools/geo_compile ../tools/geo_compile.c
	@echo "geo_compile собран: ../tools/geo_compile"

# geo-compile-host: host x86_64 для CI / Releases pipeline (G15-3).
# WHY: geo_compile запускается ТОЛЬКО на host. Роутер mmap'ит готовые .gbin
# из 4eburnet-geo IPK или скачивает через cdn_updater. Архитектура=all.
geo-compile-host:
	@echo "=== geo_compile (host) ==="
	mkdir -p $(PREBUILT_DIR)/host
	$(CC) -std=gnu2x -O2 -Iinclude -I../tools \
		-o $(PREBUILT_DIR)/host/geo_compile \
		../tools/geo_compile.c
	@ls -lh $(PREBUILT_DIR)/host/geo_compile

geo-compile-mipsel:
	$(if $(wildcard $(TC_MIPSEL)),,$(error TC_MIPSEL не найден: $(TC_MIPSEL)))
	mkdir -p $(PREBUILT_DIR)/mipsel
	$(TC_MIPSEL)/mipsel-openwrt-linux-musl-gcc \
		-std=gnu2x -O2 -static -Iinclude \
		-march=mips32r2 -mabi=32 \
		-o $(PREBUILT_DIR)/mipsel/geo_compile \
		../tools/geo_compile.c
	$(TC_MIPSEL)/mipsel-openwrt-linux-musl-strip --strip-all $(PREBUILT_DIR)/mipsel/geo_compile
	@ls -lh $(PREBUILT_DIR)/mipsel/geo_compile

geo-compile-aarch64:
	$(if $(wildcard $(TC_AARCH64)),,$(error TC_AARCH64 не найден: $(TC_AARCH64)))
	mkdir -p $(PREBUILT_DIR)/aarch64
	$(TC_AARCH64)/aarch64-openwrt-linux-musl-gcc \
		-std=gnu2x -O2 -static -march=armv8-a \
		-Iinclude \
		-o $(PREBUILT_DIR)/aarch64/geo_compile \
		../tools/geo_compile.c
	$(TC_AARCH64)/aarch64-openwrt-linux-musl-strip --strip-all $(PREBUILT_DIR)/aarch64/geo_compile
	@ls -lh $(PREBUILT_DIR)/aarch64/geo_compile

geo-compile-armv7:
	$(if $(wildcard $(TC_ARMV7)),,$(error TC_ARMV7 не найден: $(TC_ARMV7)))
	mkdir -p $(PREBUILT_DIR)/armv7
	$(TC_ARMV7)/arm-openwrt-linux-musleabihf-gcc \
		-std=gnu2x -O2 -static -march=armv7-a -mfpu=neon -mfloat-abi=hard \
		-Iinclude \
		-o $(PREBUILT_DIR)/armv7/geo_compile \
		../tools/geo_compile.c
	$(TC_ARMV7)/arm-openwrt-linux-musleabihf-strip --strip-all $(PREBUILT_DIR)/armv7/geo_compile
	@ls -lh $(PREBUILT_DIR)/armv7/geo_compile

# ── Cross-compilation (Путь A: prebuilt binary → ipk) ─────────────
SDK_BASE         ?= $(HOME)/4eburnet-dev/sdk
TC_MIPSEL        ?= $(SDK_BASE)/mipsel/sdk-mipsel/staging_dir/toolchain-mipsel_24kc_gcc-12.3.0_musl/bin
TC_AARCH64       ?= $(SDK_BASE)/aarch64/sdk-aarch64/staging_dir/toolchain-aarch64_cortex-a53_gcc-14.3.0_musl/bin
TC_ARMV7         ?= $(SDK_BASE)/armv7/sdk-armv7/staging_dir/toolchain-arm_cortex-a9+neon_gcc-13.3.0_musl/bin
WOLFSSL_MIPSEL   ?= /usr/local/musl-wolfssl-mipsel
WOLFSSL_AARCH64  ?= /usr/local/musl-wolfssl-aarch64
WOLFSSL_ARMV7    ?= /usr/local/musl-wolfssl-armv7
TC_X86_64        ?= $(SDK_BASE)/x86_64/sdk-x86_64/staging_dir/toolchain-x86_64_gcc-12.3.0_musl/bin
WOLFSSL_X86_64   ?= /usr/local/musl-wolfssl
PREBUILT_DIR     ?= ../prebuilt

sync-dashboard:
	@echo "Синхронизация dashboard.html..."
	cp src/dashboard.html \
	   ../luci-app-4eburnet/files/usr/share/4eburnet/dashboard.html
	@echo "OK: dashboard.html синхронизирован"

cross-mipsel: sync-dashboard
	$(if $(wildcard $(TC_MIPSEL)),,$(error TC_MIPSEL не найден: $(TC_MIPSEL)))
	$(if $(wildcard $(WOLFSSL_MIPSEL)),,$(error WOLFSSL_MIPSEL не найден: $(WOLFSSL_MIPSEL)))
	@echo "=== Cross-compile 4eburnetd для mipsel ==="
	$(MAKE) -f Makefile.dev PROFILE=normal \
		CC=$(TC_MIPSEL)/mipsel-openwrt-linux-musl-gcc \
		WOLFSSL_PREFIX=$(WOLFSSL_MIPSEL) \
		EXTRA_CFLAGS="-march=mips32r2 -mtune=24kc -mabi=32 -mdspr2" \
		TARGET=$(BUILDDIR)/4eburnetd-mipsel clean all
	$(TC_MIPSEL)/mipsel-openwrt-linux-musl-strip --strip-all $(BUILDDIR)/4eburnetd-mipsel
	mkdir -p $(PREBUILT_DIR)/mipsel
	cp $(BUILDDIR)/4eburnetd-mipsel $(PREBUILT_DIR)/mipsel/4eburnetd
	ls -lh $(PREBUILT_DIR)/mipsel/4eburnetd

cross-aarch64: sync-dashboard
	$(if $(wildcard $(TC_AARCH64)),,$(error TC_AARCH64 не найден: $(TC_AARCH64)))
	$(if $(wildcard $(WOLFSSL_AARCH64)),,$(error WOLFSSL_AARCH64 не найден: $(WOLFSSL_AARCH64)))
	@echo "=== Cross-compile 4eburnetd для aarch64 ==="
	$(MAKE) -f Makefile.dev PROFILE=full \
		CC=$(TC_AARCH64)/aarch64-openwrt-linux-musl-gcc \
		WOLFSSL_PREFIX=$(WOLFSSL_AARCH64) \
		EXTRA_CFLAGS="-march=armv8-a+simd -O2" \
		TARGET=$(BUILDDIR)/4eburnetd-aarch64 clean all
	$(TC_AARCH64)/aarch64-openwrt-linux-musl-strip --strip-all $(BUILDDIR)/4eburnetd-aarch64
	mkdir -p $(PREBUILT_DIR)/aarch64
	cp $(BUILDDIR)/4eburnetd-aarch64 $(PREBUILT_DIR)/aarch64/4eburnetd
	ls -lh $(PREBUILT_DIR)/aarch64/4eburnetd

cross-armv7: sync-dashboard
	$(if $(wildcard $(TC_ARMV7)),,$(error TC_ARMV7 не найден: $(TC_ARMV7)))
	$(if $(wildcard $(WOLFSSL_ARMV7)),,$(error WOLFSSL_ARMV7 не найден: $(WOLFSSL_ARMV7)))
	@echo "=== Cross-compile 4eburnetd для armv7 ==="
	$(MAKE) -f Makefile.dev PROFILE=normal \
		CC=$(TC_ARMV7)/arm-openwrt-linux-musleabihf-gcc \
		WOLFSSL_PREFIX=$(WOLFSSL_ARMV7) \
		EXTRA_CFLAGS="-march=armv7-a -mfpu=neon -mfloat-abi=hard -O2" \
		TARGET=$(BUILDDIR)/4eburnetd-armv7 clean all
	$(TC_ARMV7)/arm-openwrt-linux-musleabihf-strip --strip-all $(BUILDDIR)/4eburnetd-armv7
	mkdir -p $(PREBUILT_DIR)/armv7
	cp $(BUILDDIR)/4eburnetd-armv7 $(PREBUILT_DIR)/armv7/4eburnetd
	ls -lh $(PREBUILT_DIR)/armv7/4eburnetd

cross-x86_64: sync-dashboard
	$(if $(wildcard $(TC_X86_64)),,$(error TC_X86_64 не найден: $(TC_X86_64)))
	$(if $(wildcard $(WOLFSSL_X86_64)),,$(error WOLFSSL_X86_64 не найден: $(WOLFSSL_X86_64)))
	@echo "=== Cross-compile 4eburnetd для x86_64 ==="
	$(MAKE) -f Makefile.dev PROFILE=full \
		CC=$(TC_X86_64)/x86_64-openwrt-linux-musl-gcc \
		WOLFSSL_PREFIX=$(WOLFSSL_X86_64) \
		EXTRA_CFLAGS="-march=x86-64 -mtune=generic -O2" \
		TARGET=$(BUILDDIR)/4eburnetd-x86_64 clean all
	$(TC_X86_64)/x86_64-openwrt-linux-musl-strip --strip-all $(BUILDDIR)/4eburnetd-x86_64
	mkdir -p $(PREBUILT_DIR)/x86_64
	cp $(BUILDDIR)/4eburnetd-x86_64 $(PREBUILT_DIR)/x86_64/4eburnetd
	ls -lh $(PREBUILT_DIR)/x86_64/4eburnetd

check-cross:
	@echo "Cross-compile flags check (mipsel):"
	@echo "  TC_MIPSEL path required: $(TC_MIPSEL)"
	@echo "  WOLFSSL_MIPSEL path required: $(WOLFSSL_MIPSEL)"
	@echo "  EBURNET_VERSION: $(EBURNET_VERSION)"
	@echo "OK check-cross"

CFLAGS_EXTRA ?=
asan: CFLAGS_EXTRA += -fsanitize=address,undefined -fno-omit-frame-pointer
asan: CFLAGS_EXTRA += -DEBURNET_ASAN=1
asan: CC = gcc
asan:
	$(MAKE) -f Makefile.dev EXTRA_CFLAGS="$(CFLAGS_EXTRA)" CC=$(CC) all

help:
	@echo "4eburNet Makefile.dev — доступные таргеты:"
	@echo ""
	@echo "  make                     — сборка x86_64 dev бинарника"
	@echo "  make test                — запустить все тесты (56 суитов)"
	@echo "  make clean               — удалить артефакты сборки"
	@echo "  make asan                — сборка с AddressSanitizer + UBSan"
	@echo "  make check-cross         — проверить флаги кросс-сборки (dry-run)"
	@echo "  make geo-compile         — собрать geo_compile для хоста"
	@echo "  make geo-compile-mipsel  — кросс-компиляция geo_compile для mipsel"
	@echo "  make cross-mipsel        — кросс-компиляция MIPS (TC_MIPSEL=path)"
	@echo "  make cross-aarch64       — кросс-компиляция ARM64 (TC_AARCH64=path)"
	@echo "  make cross-armv7         — кросс-компиляция ARMv7 (TC_ARMV7=path)"
	@echo "  make help                — этот список"
	@echo ""

.PHONY: all clean run install-vm test help asan check-cross \
  test-uri test-udp test-cc test-dpi-filter test-dpi-payload test-dpi-strategy \
  test-cdn-updater test-hmac-sha256 test-shadowtls test-ipc-safety test-config-parsing \
  test-blake2b test-salamander test-varint test-dns-geosite test-sniffer test-geo-bin test-ipc-async \
  test-bloom test-simd test-dpi-adapt test-ja3 test-http-devices test-tls13-wire test-pbk-decode \
  test-vision-addons test-vision-state test-reality-keys test-reality-auth \
  test-tls13-chrome test-tls13-record test-tls13-hs-unit test-reality-conn-unit \
  test-ptr-resolver test-rules-engine-priority test-or-regex test-dispatcher-resolve test-ws-frame \
  test-hc-vless test-hc-vmess test-hc-anytls test-hc-tuic \
  test-ws-handshake test-ecdh-wolfssl test-reality-roundtrip test-dns-cookie \
  geo-compile geo-compile-host geo-compile-mipsel geo-compile-aarch64 geo-compile-armv7 \
  cross-mipsel cross-aarch64 cross-armv7 sync-dashboard \
  test-vmess test-clash-yaml test-net-utils test-proxy-group-lb
