#!/usr/bin/lua
--[[
  rpcd backend для 4eburNet
  Протокол: JSON-RPC через stdin/stdout
  Связь с 4eburnetd через Unix socket /var/run/4eburnet.sock
--]]

-- Попробовать оба JSON модуля
local json_ok, json_mod = pcall(require, "luci.jsonc")
if not json_ok then
    json_ok, json_mod = pcall(require, "cjson")
    if not json_ok then
        -- Минимальный fallback для базовых типов
        json_mod = {
            stringify = function(t)
                if type(t) == "table" then
                    local parts = {}
                    for k, v in pairs(t) do
                        local val
                        if type(v) == "string" then
                            val = '"' .. v:gsub('\\','\\\\'):gsub('"','\\"') .. '"'
                        elseif type(v) == "boolean" then
                            val = tostring(v)
                        elseif type(v) == "number" then
                            val = tostring(v)
                        elseif type(v) == "table" then
                            val = json_mod.stringify(v)
                        else
                            val = '"?"'
                        end
                        parts[#parts+1] = '"' .. tostring(k) .. '":' .. val
                    end
                    return "{" .. table.concat(parts, ",") .. "}"
                end
                return tostring(t)
            end,
            parse = function(s) return nil end
        }
    end
end

local nixio_ok, nixio = pcall(require, "nixio")

local SOCKET  = "/var/run/4eburnet.sock"
local VERSION = 1
local TIMEOUT = 3

-- IPC header: version(u8) cmd(u8) length(u16 BE) req_id(u32 BE) = 8 байт
local function pack_hdr(cmd, plen, rid)
    return string.char(
        VERSION, cmd,
        math.floor(plen / 256) % 256, plen % 256,
        math.floor(rid / 16777216) % 256,
        math.floor(rid / 65536) % 256,
        math.floor(rid / 256) % 256,
        rid % 256)
end

local function ipc_call(cmd, payload)
    if not nixio_ok then return nil, "nixio недоступен" end
    payload = payload or ""
    local s = nixio.socket("unix", "stream")
    if not s then return nil, "no socket" end
    s:settimeout(TIMEOUT)
    local ok, e = s:connect(SOCKET)
    if not ok then s:close(); return nil, "connect: " .. tostring(e) end
    s:send(pack_hdr(cmd, #payload, os.time() % 65535) .. payload)
    local hdr = s:recv(8)
    if not hdr or #hdr < 8 then s:close(); return nil, "no hdr" end
    local plen = hdr:byte(3) * 256 + hdr:byte(4)
    local body = plen > 0 and s:recv(plen) or ""
    s:close()
    -- Найти JSON в ответе
    local js = (body or ""):match("[{%[].*")
    return js or body, nil
end

local function is_running()
    local f = io.open("/var/run/4eburnet.pid", "r")
    if not f then return false end
    local pid = tonumber(f:read("*l")); f:close()
    if not pid then return false end
    return os.execute("kill -0 " .. pid .. " 2>/dev/null") == 0
end

-- Методы rpcd

local methods = {}

methods.status = function(args)
    local running = is_running()
    local data = {}
    if running then
        local r, _ = ipc_call(1)  -- IPC_CMD_STATUS
        if r then
            local ok, d = pcall(json_mod.parse, r)
            if ok and d then data = d end
        end
    end
    return {
        running   = running,
        uptime    = data.uptime or 0,
        mode      = data.mode or "unknown",
        timestamp = os.time()
    }
end

methods.stats = function(args)
    local r, e = ipc_call(4)  -- IPC_CMD_STATS
    if e then return { error = e, connections = 0, dns_queries = 0 } end
    local ok, d = pcall(json_mod.parse, r or "")
    return (ok and d) or { raw = r, connections = 0, dns_queries = 0 }
end

methods.reload = function(args)
    local _, e = ipc_call(2)  -- IPC_CMD_RELOAD
    return { ok = (e == nil), error = e }
end

methods.stop = function(args)
    local _, e = ipc_call(3)  -- IPC_CMD_STOP
    return { ok = (e == nil), error = e }
end

methods.restart = function(args)
    os.execute("/etc/init.d/4eburnet stop 2>/dev/null; sleep 1; /etc/init.d/4eburnet start 2>/dev/null")
    return { ok = true }
end

methods.groups = function(args)
    local r, e = ipc_call(20)  -- IPC_CMD_GROUP_LIST
    if e then return { error = e, groups = {} } end
    local ok, d = pcall(json_mod.parse, r or "")
    return (ok and d) or { groups = {}, raw = r }
end

methods.group_select = function(args)
    local payload = json_mod.stringify(args or {})
    local _, e = ipc_call(21, payload)  -- IPC_CMD_GROUP_SELECT
    return { ok = (e == nil), error = e }
end

methods.logs = function(args)
    local n = tonumber((args or {}).lines) or 50
    if n > 500 then n = 500 end
    local lines = {}
    local f = io.open("/tmp/4eburnet.log", "r")
    if f then
        local all = {}
        for l in f:lines() do all[#all+1] = l end
        f:close()
        local s = math.max(1, #all - n + 1)
        for i = s, #all do lines[#lines+1] = all[i] end
    end
    return { lines = lines, count = #lines }
end

methods.wan_ip = function(args)
    local ip
    local f = io.popen("ip route get 8.8.8.8 2>/dev/null")
    if f then
        local line = f:read("*l"); f:close()
        if line then ip = line:match("src%s+(%S+)") end
    end
    return { ip = ip or "unknown", timestamp = os.time() }
end

methods.devices = function(args)
    local devs = {}
    local f = io.open("/proc/net/arp", "r")
    if f then
        f:read("*l")  -- пропустить заголовок
        for l in f:lines() do
            local ip, _, _, mac, _, iface = l:match(
                "(%S+)%s+(%S+)%s+(%S+)%s+(%S+)%s+(%S+)%s+(%S+)")
            if ip and mac and mac ~= "00:00:00:00:00:00" then
                devs[#devs+1] = { ip = ip, mac = mac:upper(), iface = iface }
            end
        end
        f:close()
    end
    return { devices = devs, count = #devs }
end

methods.tproxy_status = function(args)
    local f = io.open("/sys/module/nft_tproxy/refcnt", "r")
    local available = f ~= nil
    if f then f:close() end
    return { available = available }
end

-- rpcd dispatch

local mode = arg[1]

if mode == "list" then
    local list = {}
    for k, _ in pairs(methods) do list[k] = {} end
    list.group_select = { group = "", idx = 0 }
    list.logs = { lines = 50 }
    io.write(json_mod.stringify(list) .. "\n")

elseif mode == "call" then
    local method = arg[2]
    local fn = methods[method]
    if not fn then
        io.write('{"error":"unknown method"}\n')
        os.exit(1)
    end
    local input = io.read("*a")
    local ok, args = pcall(json_mod.parse, input or "")
    local result = fn(ok and args or {})
    io.write(json_mod.stringify(result) .. "\n")
end
