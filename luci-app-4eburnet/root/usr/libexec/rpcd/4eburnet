#!/usr/bin/lua
--[[
  rpcd backend для 4eburNet v0.3 (minimal)
  Единственный метод: status — состояние демона.
  Весь UI-функционал переведён на прямые /api/* запросы к http_server.c.
--]]

-- ── JSON ──────────────────────────────────────────────────────────
local function json_encode(v)
    local t = type(v)
    if t == "boolean" then return tostring(v) end
    if t == "number"  then return tostring(v) end
    if t == "string"  then
        return '"' .. v:gsub('[\\"/%c]', function(c)
            local esc = {['"']='\\"', ['\\']='\\\\', ['/']='\\/',
                         ['\n']='\\n', ['\r']='\\r', ['\t']='\\t'}
            return esc[c] or ('\\u00' .. string.format('%02x', c:byte()))
        end) .. '"'
    end
    if t == "table" then
        local is_arr = (#v > 0)
        if is_arr then
            local a = {}
            for i = 1, #v do a[i] = json_encode(v[i]) end
            return "[" .. table.concat(a, ",") .. "]"
        end
        local a = {}
        for k, val in pairs(v) do
            if type(k) == "string" then
                a[#a+1] = json_encode(k) .. ":" .. json_encode(val)
            end
        end
        return "{" .. table.concat(a, ",") .. "}"
    end
    return "null"
end

local function jstr(v)
    local ok, s = pcall(json_encode, v)
    return ok and s or '{"error":"encode failed"}'
end

local function jparse(s)
    local ok_j, json = pcall(require, "luci.jsonc")
    if not ok_j then ok_j, json = pcall(require, "cjson") end
    if ok_j and json then
        local ok2, r = pcall(json.parse or json.decode, s)
        if ok2 then return r end
    end
    return {}
end

-- ── Утилиты ───────────────────────────────────────────────────────
local function is_running()
    local f = io.popen("pgrep -x 4eburnetd 2>/dev/null")
    if not f then return false end
    local pid = f:read("*l")
    f:close()
    return pid ~= nil and pid ~= ""
end

-- ── Методы ────────────────────────────────────────────────────────
local methods = {}

methods.status = function(_)
    return {
        status  = is_running() and "running" or "stopped",
        version = "1.0.0"
    }
end

-- ── rpcd dispatch ─────────────────────────────────────────────────
local mode = arg[1]

if mode == "list" then
    io.write(jstr({ status = {} }) .. "\n")

elseif mode == "call" then
    local method = arg[2]
    local fn = methods[method]
    if not fn then
        io.write('{"error":"unknown method: ' .. tostring(method) .. '"}\n')
        os.exit(1)
    end
    local input = io.read("*a") or ""
    local call_args = jparse(input) or {}
    local result = fn(call_args)
    io.write(jstr(result) .. "\n")
end
