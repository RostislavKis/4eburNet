# ── Правила маршрутизации (rules) ────────────────────────────────
# REJECT — нежелательные домены
config traffic_rule
	option type 'DOMAIN-SUFFIX'
	option value 'wpad'
	option target 'REJECT'
	option priority '1000'

config traffic_rule
	option type 'DOMAIN-KEYWORD'
	option value 'wpad'
	option target 'REJECT'
	option priority '990'

# DIRECT — LAN / локальные адреса
config traffic_rule
	option type 'IP-CIDR'
	option value '127.0.0.0/8'
	option target 'DIRECT'
	option priority '980'

config traffic_rule
	option type 'IP-CIDR'
	option value '192.168.0.0/16'
	option target 'DIRECT'
	option priority '970'

config traffic_rule
	option type 'IP-CIDR'
	option value '10.0.0.0/8'
	option target 'DIRECT'
	option priority '960'

config traffic_rule
	option type 'IP-CIDR'
	option value '172.16.0.0/12'
	option target 'DIRECT'
	option priority '950'

config traffic_rule
	option type 'DOMAIN-SUFFIX'
	option value 'local'
	option target 'DIRECT'
	option priority '940'

# NTP — напрямую (DST-PORT 123)
config traffic_rule
	option type 'DST-PORT'
	option value '123'
	option target 'DIRECT'
	option priority '930'

# DIRECT — медиа, торренты (собственные списки)
config traffic_rule
	option type 'RULE-SET'
	option value 'direct_media'
	option target 'DIRECT'
	option priority '920'

config traffic_rule
	option type 'RULE-SET'
	option value 'anime_trackers'
	option target 'DIRECT'
	option priority '910'

# Примечание: PROCESS-NAME и AND-правила не поддерживаются в 4eburNet
# Пропущены: PROCESS-NAME lampa.exe/lampac.exe, AND TCP/UDP DST-PORT torrent

# GEMINI — Google / YouTube / Gemini AI
config traffic_rule
	option type 'RULE-SET'
	option value 'google_gemini'
	option target 'GEMINI'
	option priority '900'

# TELEGRAM
config traffic_rule
	option type 'RULE-SET'
	option value 'telegram_rules'
	option target 'TELEGRAM'
	option priority '880'

config traffic_rule
	option type 'RULE-SET'
	option value 'telegram_extra'
	option target 'TELEGRAM'
	option priority '870'

# DISCORD
config traffic_rule
	option type 'RULE-SET'
	option value 'discord_rules'
	option target 'DISCORD'
	option priority '860'

# MAIN-PROXY — заблокированные сервисы
config traffic_rule
	option type 'RULE-SET'
	option value 'github_copilot'
	option target 'MAIN-PROXY'
	option priority '850'

config traffic_rule
	option type 'RULE-SET'
	option value 'openai_rules'
	option target 'MAIN-PROXY'
	option priority '840'

config traffic_rule
	option type 'RULE-SET'
	option value 'twitter_rules'
	option target 'MAIN-PROXY'
	option priority '830'

config traffic_rule
	option type 'RULE-SET'
	option value 'instagram_rules'
	option target 'MAIN-PROXY'
	option priority '820'

config traffic_rule
	option type 'RULE-SET'
	option value 'facebook_rules'
	option target 'MAIN-PROXY'
	option priority '810'

config traffic_rule
	option type 'RULE-SET'
	option value 'whatsapp_rules'
	option target 'MAIN-PROXY'
	option priority '800'

config traffic_rule
	option type 'RULE-SET'
	option value 'notion_rules'
	option target 'MAIN-PROXY'
	option priority '790'

config traffic_rule
	option type 'RULE-SET'
	option value 'microsoft_rules'
	option target 'MAIN-PROXY'
	option priority '780'

config traffic_rule
	option type 'RULE-SET'
	option value 'oracle_rules'
	option target 'MAIN-PROXY'
	option priority '770'

config traffic_rule
	option type 'RULE-SET'
	option value 'tools_rules'
	option target 'MAIN-PROXY'
	option priority '760'

config traffic_rule
	option type 'RULE-SET'
	option value 'proxy_misc'
	option target 'MAIN-PROXY'
	option priority '750'

config traffic_rule
	option type 'RULE-SET'
	option value 'ru_blocked'
	option target 'MAIN-PROXY'
	option priority '740'

# opencck — заблокированные в РФ ресурсы → прокси (выше GEOIP RU)
config traffic_rule
	option type 'RULE-SET'
	option value 'opencck_domains'
	option target 'MAIN-PROXY'
	option priority '230'

config traffic_rule
	option type 'RULE-SET'
	option value 'opencck_cidr'
	option target 'MAIN-PROXY'
	option priority '220'

# RU-домены — напрямую (GEOIP)
config traffic_rule
	option type 'GEOIP'
	option value 'RU'
	option target 'DIRECT'
	option priority '200'

# Catch-all — всё остальное напрямую
config traffic_rule
	option type 'MATCH'
	option value ''
	option target 'DIRECT'
	option priority '10'
