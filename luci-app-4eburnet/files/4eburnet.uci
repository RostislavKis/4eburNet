# /etc/config/4eburnet
# Адаптировано из config.yaml (Clash/Mihomo → 4eburNet UCI)
# Настройка через LuCI: Services → 4eburNet

config 4eburnet 'main'
	option enabled '1'
	option mode 'rules'
	option log_level 'info'
	option api_token 'changeme'
	option lan_interface 'br-lan'
	option region 'ru'
	option geo_dir '/etc/4eburnet/geo'
	option flow_offload '0'
	option tc_fast_enabled '0'
	option lan_prefix '192.168.2.0'
	option lan_mask '255.255.255.0'
	option dpi_enabled '0'
	option dpi_split_pos '1'
	option dpi_fake_ttl '5'
	option dpi_fake_repeats '8'
	option dpi_fake_sni 'www.google.com'
	option cdn_update_interval_days '7'

# ── DNS ──────────────────────────────────────────────────────────────
# fake-ip: RU-домены → upstream_bypass (прямой резолвинг)
#          остальное  → upstream_proxy (DoH через прокси)
config dns 'dns'
	option enabled '1'
	option listen_port '53'
	option upstream_bypass '1.1.1.1'
	option upstream_proxy 'https://dns.google/dns-query'
	option upstream_default '1.1.1.1'
	option upstream_fallback '9.9.9.9'
	option upstream_port '53'
	option cache_size '512'
	option parallel_query '1'
	option fake_ip_enabled '1'
	option fake_ip_range '198.51.100.0/24'
	option fake_ip_ttl '60'
	option doh_enabled '1'
	option doh_url 'https://dns.google/dns-query'
	option doh_ip '8.8.8.8'
	option doh_sni 'dns.google'
	list block_geosite 'ads'
	list block_geosite 'trackers'
	list block_geosite 'threats'

# ── DNS bypass для хостов обновления (реальный IP, не fake-ip) ────
config dns_rule
	option type 'bypass'
	option pattern '*.opencck.org'

config dns_rule
	option type 'bypass'
	option pattern 'iplist.opencck.org'

config dns_rule
	option type 'bypass'
	option pattern '*.easylist.to'

config dns_rule
	option type 'bypass'
	option pattern '*.urlhaus.abuse.ch'

config dns_rule
	option type 'bypass'
	option pattern '*.githubusercontent.com'

config dns_rule
	option type 'bypass'
	option pattern '*.jsdelivr.net'

# ── Серверы (proxies) ─────────────────────────────────────────────
# Обычный WARP (WireGuard, без AmneziaWG junk)
config server 'warp_ipv4'
	option name 'WARP-IPv4'
	option type 'awg'
	option server '162.159.192.1'
	option port '4500'
	option awg_private_key 'CCnJX3zMt8S0aehfYBo0703qv1azDDDHfG/0QYj1MUw='
	option awg_public_key 'bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo='
	option awg_mtu '1280'
	option awg_dns '1.1.1.1,1.0.0.1'
	option awg_reserved '240,220,224'

# AmneziaWG — вариант 1 (junk 120/23-911)
config server 'awg_v1'
	option name 'AWG v1'
	option type 'awg'
	option server '162.159.192.1'
	option port '4500'
	option awg_private_key 'CCnJX3zMt8S0aehfYBo0703qv1azDDDHfG/0QYj1MUw='
	option awg_public_key 'bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo='
	option awg_mtu '1280'
	option awg_dns '1.1.1.1,1.0.0.1'
	option awg_reserved '240,220,224'
	option awg_jc '120'
	option awg_jmin '23'
	option awg_jmax '911'
	option awg_s1 '0'
	option awg_s2 '0'
	option awg_h1 '1'
	option awg_h2 '2'
	option awg_h3 '4'
	option awg_h4 '3'
	option awg_i1 ''

# AmneziaWG — вариант 2 (другой init packet)
config server 'awg_v2'
	option name 'AWG v2'
	option type 'awg'
	option server '162.159.192.1'
	option port '4500'
	option awg_private_key 'CCnJX3zMt8S0aehfYBo0703qv1azDDDHfG/0QYj1MUw='
	option awg_public_key 'bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo='
	option awg_mtu '1280'
	option awg_dns '1.1.1.1,1.0.0.1'
	option awg_reserved '240,220,224'
	option awg_jc '120'
	option awg_jmin '23'
	option awg_jmax '911'
	option awg_s1 '0'
	option awg_s2 '0'
	option awg_h1 '1'
	option awg_h2 '2'
	option awg_h3 '4'
	option awg_h4 '3'
	option awg_i1 ''

# AmneziaWG — вариант 3 (SIP-пакеты + j1 padding, itime=120)
config server 'awg_v3'
	option name 'AWG v3'
	option type 'awg'
	option server '162.159.192.1'
	option port '4500'
	option awg_private_key 'CCnJX3zMt8S0aehfYBo0703qv1azDDDHfG/0QYj1MUw='
	option awg_public_key 'bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo='
	option awg_mtu '1280'
	option awg_dns '1.1.1.1,1.0.0.1'
	option awg_reserved '240,220,224'
	option awg_jc '120'
	option awg_jmin '23'
	option awg_jmax '911'
	option awg_s1 '0'
	option awg_s2 '0'
	option awg_h1 '1'
	option awg_h2 '2'
	option awg_h3 '4'
	option awg_h4 '3'
	option awg_i1 ''
	option awg_i2 ''
	option awg_j1 'abcdef1234567890'
	option awg_itime '120'

# ── Подписочные провайдеры (proxy-providers) ─────────────────────
# Примечание: кастомные HTTP-заголовки (User-Agent, x-hwid и т.д.) не поддерживаются
config proxy_provider 'prvtvpn'
	option name 'PrivateVPN'
	option type 'url'
	option url 'https://accessbyme.com/multiserver.php?access=u0AGP9dUzoTEySf6qD&fmt=clash'
	option path '/etc/4eburnet/providers/privatevpn.yaml'
	option interval '3600'
	option enabled '1'

config proxy_provider 'arza'
	option name 'ARZA'
	option type 'url'
	option url 'https://sub.arza.top/dDez5VtAUQgNAnv0'
	option path '/etc/4eburnet/providers/arza.yaml'
	option interval '3600'
	option enabled '1'

# ── Группы прокси (proxy-groups) ─────────────────────────────────
# Gemini / YouTube — select, управляется вручную или latency-monitor
config proxy_group 'gemini'
	option name 'GEMINI'
	option type 'select'
	option providers 'PrivateVPN ARZA'
	option filter '^(?!.*(Россия|Russia|Kazakhstan|Казахстан|Armenia|Армения|Torrent|torrent|Истекает|Купить|WARP|AWG|Германия|Germany|Эстония|Латвия|Latvia)).*$'
	option enabled '1'

# PrivateVPN — url-test, автовыбор лучшего
config proxy_group 'prvtvpn_group'
	option name 'PrvtVPN'
	option type 'url-test'
	option providers 'PrivateVPN'
	option filter '^(?!.*(Russia|Россия|Kazakhstan|Казахстан|Armenia|Армения|Torrent|torrent|Истекает|Купить|WARP|AWG)).*$'
	option url 'https://cp.cloudflare.com/generate_204'
	option interval '300'
	option tolerance_ms '50'
	option enabled '1'

# ARZA — url-test, автовыбор лучшего
config proxy_group 'arza_group'
	option name 'ARZA'
	option type 'url-test'
	option providers 'ARZA'
	option filter '^(?!.*(Armenia|Армения|Истекает|Купить|Torrent|torrent)).*$'
	option url 'https://cp.cloudflare.com/generate_204'
	option interval '300'
	option tolerance_ms '50'
	option enabled '1'

# Основной прокси — url-test, лучший из обоих провайдеров
config proxy_group 'main_proxy'
	option name 'MAIN-PROXY'
	option type 'url-test'
	option providers 'PrivateVPN ARZA'
	option filter '^(?!.*(Россия|Russia|Kazakhstan|Казахстан|Armenia|Армения|Torrent|torrent|Истекает|Купить|WARP|AWG)).*$'
	option url 'https://cp.cloudflare.com/generate_204'
	option interval '300'
	option tolerance_ms '50'
	option enabled '1'

# Telegram — url-test: PrvtVPN + AWG варианты
config proxy_group 'telegram'
	option name 'TELEGRAM'
	option type 'url-test'
	list servers 'WARP-IPv4'
	list servers 'AWG v1'
	list servers 'AWG v2'
	list servers 'AWG v3'
	option url 'https://api.telegram.org/'
	option interval '60'
	option tolerance_ms '100'
	option enabled '1'

# Discord — url-test: AWG варианты
config proxy_group 'discord'
	option name 'DISCORD'
	option type 'url-test'
	list servers 'AWG v1'
	list servers 'AWG v2'
	list servers 'AWG v3'
	option url 'https://cp.cloudflare.com/generate_204'
	option interval '120'
	option tolerance_ms '50'
	option enabled '1'

# ── Rule providers (списки правил) ────────────────────────────────

# opencck — актуальный список РКН (iplist.opencck.org)
config rule_provider 'opencck_domains'
	option type 'http'
	option url 'https://iplist.opencck.org/?format=text&type=domains&data=domains'
	option path '/etc/4eburnet/rules/opencck-domains.lst'
	option format 'domain'
	option interval '21600'
	option enabled '1'

config rule_provider 'opencck_cidr'
	option type 'http'
	option url 'https://iplist.opencck.org/?format=text&type=cidr&data=cidr4'
	option path '/etc/4eburnet/rules/opencck-cidr.lst'
	option format 'ipcidr'
	option interval '21600'
	option enabled '1'

config rule_provider 'ru_blocked'
	option type 'http'
	option url 'https://cdn.jsdelivr.net/gh/shvchk/unblock-net@main/lists/clash/ru-blocked'
	option path '/etc/4eburnet/rules/ru-blocked.txt'
	option format 'domain'
	option interval '86400'
	option enabled '1'

